// Azure OpenAI chat model provider
configurable string azureOpenAiServiceUrl = ?;
configurable string azureOpenAiApiKey = ?;
configurable string azureOpenAiDeploymentId = ?;
configurable string azureOpenAiApiVersion = ?;

// Azure OpenAI embedding provider
configurable string azureEmbeddingServiceUrl = ?;
configurable string azureEmbeddingApiKey = ?;
configurable string azureEmbeddingApiVersion = ?;
configurable string azureEmbeddingDeploymentId = ?;

// Azure AI Search knowledge base
configurable string azureAiSearchServiceUrl = ?;
configurable string azureAiSearchApiKey = ?;
configurable string azureAiSearchIndexName = ?;
